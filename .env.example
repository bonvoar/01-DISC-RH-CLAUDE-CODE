# Database (Supabase PostgreSQL - session pooler, port 5432)
DATABASE_URL="postgresql://user:password@host.pooler.supabase.com:5432/postgres"

# NextAuth v5 (AUTH_SECRET é o nome correto na v5) — gere com: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Anthropic / Claude API
ANTHROPIC_API_KEY=""
# Haiku 4.5 chosen for cost at multi-tenant scale; bump to claude-sonnet-5/claude-opus-4-8 if guardrail issues appear
ANTHROPIC_MODEL="claude-haiku-4-5"

# Resend (e-mail transacional)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
DPO_EMAIL=""

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (upload PDFs/DOCX)
BLOB_STORE_ID=""
BLOB_READ_WRITE_TOKEN=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Inngest — INNGEST_DEV=1 para dev local (dispensa EVENT_KEY/SIGNING_KEY reais)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
INNGEST_DEV=1

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# LGPD - versão atual do termo de consentimento
CONSENT_VERSION="1.0"
